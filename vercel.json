{
  "version": 2,
  "buildCommand": "if [ -d \"client\" ]; then cd client && npm install && npm run build; else npm install && npm run build; fi",
  "outputDirectory": "client/dist",
  "installCommand": "npm install && npm install --prefix client",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/client/dist/$1"
    }
  ]
}